# Copy this file to .env.local for local development
# Set this to your Railway server URL after deploying
# Example: VITE_WS_URL=wss://luxmirror-server.up.railway.app/ws
VITE_WS_URL=

# Secret key to access the admin panel (/admin?key=YOUR_KEY)
# Set this in Vercel environment variables — never commit the real value here
VITE_ADMIN_KEY=
